# Questrade API Wrapper — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# OAuth Credentials (required)
# Obtain from https://www.questrade.com/api/documentation/getting-started
# ---------------------------------------------------------------------------
QUESTRADE_CLIENT_ID=your_client_id_here
QUESTRADE_CLIENT_SECRET=your_client_secret_here   # optional for public clients
QUESTRADE_REDIRECT_URI=http://localhost:3000/callback

# ---------------------------------------------------------------------------
# Token Storage
# ---------------------------------------------------------------------------
# Path to the JSON file where the access/refresh token is persisted
TOKEN_STORAGE_PATH=.keys/tokens.json

# 32-byte hex key for AES-256-CBC token encryption (strongly recommended in production)
# Generate with: openssl rand -hex 32
# WARNING: Never leave this empty in production — tokens will be stored in plaintext.
# Keep this value secret; anyone with it can decrypt stored tokens.
TOKEN_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info          # trace | debug | info | warn | error
LOG_FILE=.keys/logs/questrade-api.log
LOG_PRETTY=true         # true = colorized console output; false = JSON

# ---------------------------------------------------------------------------
# Rate Limiting (must not exceed Questrade API limits)
# ---------------------------------------------------------------------------
RATE_LIMIT_ACCOUNT_RPS=30   # account endpoint requests per second
RATE_LIMIT_MARKET_RPS=20    # market data endpoint requests per second

# ---------------------------------------------------------------------------
# Streaming
# ---------------------------------------------------------------------------
# Override if your API server returns a specific stream URI
# STREAM_URI=wss://streaming.questrade.com
